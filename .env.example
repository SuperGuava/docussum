# Supabase PostgreSQL
# - Next.js: .env.local 자동 로드
# - drizzle-kit (pnpm db:push 등): drizzle.config.ts → db/load-env.ts 가 .env.local 로드
# Supabase 대시보드 → Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# Epic 3 — Supabase Auth (Google OAuth)
# Supabase → Project Settings → API
# Authentication → URL Configuration (실제 dev 포트에 맞게)
#   Site URL: http://localhost:3002
#   Redirect: http://localhost:3002/auth/callback
# (선택) 로그인 오류 안내용
# NEXT_PUBLIC_SITE_URL=http://localhost:3002/auth/callback
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# 아래 둘 중 하나 (대시보드에 표시되는 이름에 맞게)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Epic 2 dev user (Epic 3 완료 전까지; ALLOW_DEV_USER=true 시에만 fallback)
# DEV_USER_ID=00000000-0000-4000-8000-000000000001
# ALLOW_DEV_USER=true

# Google Gemini — https://aistudio.google.com/apikey 에서 발급 (Generative Language API)
# 따옴표 없이 한 줄: GEMINI_API_KEY=AIza...
GEMINI_API_KEY=
# YouTube URL 요약 권장: gemini-2.5-flash (기본값)
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_API_KEY 가 없을 때만 사용
# GOOGLE_API_KEY=

# Epic 4 — Stripe (Test mode)
# 상품/Price 등록: Stripe MCP (docs/stripe/test-mode-catalog.md)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...   # stripe listen 출력
# STRIPE_PRICE_ID_30=price_1TeEJPIYzHZbjIp3QDStclbH
# STRIPE_PRICE_ID_50=price_1TeEJPIYzHZbjIp3V09fcDu2
# STRIPE_PRICE_ID_100=price_1TeEJPIYzHZbjIp3hJCN0Spv

# Epic 5 — Resend (요약 완료 알림, Resend 기본 도메인)
# https://resend.com/api-keys
# RESEND_API_KEY=re_...
# 발신 주소 (미설정 시 DocuSumm <onboarding@resend.dev>)
# RESEND_FROM_EMAIL=DocuSumm <onboarding@resend.dev>
# 이메일·결제 링크용 공개 URL (미설정 시 NEXT_PUBLIC_SITE_URL 또는 localhost:3002)
# NEXT_PUBLIC_APP_URL=http://localhost:3002
